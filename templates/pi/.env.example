# templates/pi — environment.
#
# Copy this file to .env and edit, or run ./setup-host.sh to fill safe defaults.
# WORKSPACE_PATH and AGENT_HOME_PATH are required on purpose; keep both outside
# the sannux repository.

# UID/GID matched to the host user. Run `id -u` and `id -g` to get yours.
# On macOS this is less critical because Docker Desktop translates ownership,
# but using the real values keeps examples consistent across systems.
USER_UID=1000
USER_GID=1000

# Project folder mounted at /workspace inside the container. Use an absolute
# path outside this repo. If this stays empty, ./setup-host.sh uses:
# ~/sannux-data/workspaces/pi
# Example: WORKSPACE_PATH=/srv/example-data/workspaces/my-project
WORKSPACE_PATH=

# Persistent agent home mounted at /home/agent inside the container.
# This stores auth, config, sessions, packages, logs, and other Pi state. If
# this stays empty, ./setup-host.sh uses:
# ~/sannux-data/agent-homes/pi
# Example: AGENT_HOME_PATH=/srv/example-data/agent-homes/pi
AGENT_HOME_PATH=

# Terminal colors for TUI agents. xterm-256color works well in most terminals.
SANNUX_TERM=xterm-256color
SANNUX_COLORTERM=truecolor
# Optional: force ANSI colors even when a tool is unsure. Can make piped output noisy.
# SANNUX_FORCE_COLOR=1

# Optional provider API keys. Pi also supports subscription login with `/login`.
# Auth, settings, sessions, extensions, skills, packages, and model config
# persist under AGENT_HOME_PATH/.pi/agent across container destructions.
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=...
# OPENROUTER_API_KEY=...

# Optional: force Pi's config directory. The default already resolves to
# /home/agent/.pi/agent, but keeping this explicit documents what is persisted.
PI_CODING_AGENT_DIR=/home/agent/.pi/agent

# Resource caps. Not security; just limits for runaway commands.
# On a VPS, adjust these to the machine size.
MEM_LIMIT=4g
CPU_LIMIT=4
