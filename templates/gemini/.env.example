# templates/gemini — environment.
#
# Copy this file to .env and edit, or run ./setup-host.sh to fill safe defaults.
# Keep WORKSPACE_PATH and AGENT_HOME_PATH outside the sannux repository.

# UID/GID matched to the host user. Run `id -u` and `id -g` to get yours.
# On macOS this is less critical because Docker Desktop translates ownership,
# but using the real values keeps examples consistent across systems.
USER_UID=1000
USER_GID=1000

# Project folder mounted at /workspace inside the container.
# Use an absolute path outside this repo. ./setup-host.sh creates it when blank.
# Example: WORKSPACE_PATH=/path/to/workspaces/my-project
WORKSPACE_PATH=

# Persistent agent home mounted at /home/agent inside the container.
# This stores auth, config, project registry, sessions, history, logs, and cache.
# ./setup-host.sh creates it when blank.
# Example: AGENT_HOME_PATH=/path/to/agent-homes/gemini
AGENT_HOME_PATH=

# Terminal colors for TUI agents. xterm-256color works well in most terminals.
SANNUX_TERM=xterm-256color
SANNUX_COLORTERM=truecolor
# Optional: force ANSI colors even when a tool is unsure. Can make piped output noisy.
# SANNUX_FORCE_COLOR=1

# Auth: pick ONE of the three options below.
#
# 1) AI Studio API key — simplest.
# GEMINI_API_KEY=...
#
# 2) Google OAuth — leave everything blank, run `gemini` once and pick
#    "Sign in with Google". Token persists in AGENT_HOME_PATH/.gemini/.
#
# 3) Vertex AI on Google Cloud.
# GOOGLE_API_KEY=...
# GOOGLE_GENAI_USE_VERTEXAI=true
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# Resource caps. Not security; just limits for runaway commands.
# On a VPS, adjust these to the machine size.
MEM_LIMIT=4g
CPU_LIMIT=4
