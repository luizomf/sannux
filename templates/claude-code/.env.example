# templates/claude-code — environment.
#
# Copy this file to .env. Editing WORKSPACE_PATH and AGENT_HOME_PATH is best,
# but setup-host.sh falls back to a dedicated default base under $HOME when empty.

# UID/GID matched to the host user. Run `id -u` and `id -g` to get yours.
# On macOS this is less critical because Docker Desktop translates ownership,
# but using the real values keeps examples consistent across systems.
USER_UID=1000
USER_GID=1000

# Project folder mounted at /workspace inside the container.
# Use an absolute path outside this repo.
# Example: WORKSPACE_PATH=/path/to/workspaces/my-project
WORKSPACE_PATH=

# Persistent agent home mounted at /home/agent inside the container.
# This stores Claude auth, config, sessions, history, logs, and memory.
# Example: AGENT_HOME_PATH=/path/to/agent-homes/claude-code
AGENT_HOME_PATH=

# Terminal colors for TUI agents. xterm-256color works well in most terminals.
SANNUX_TERM=xterm-256color
SANNUX_COLORTERM=truecolor
# Optional: force ANSI colors even when a tool is unsure. Can make piped output noisy.
# SANNUX_FORCE_COLOR=1

# Optional preview ports for apps started by the Remote Control daemon.
# Regular `docker compose run --rm agent` sessions publish ports explicitly
# per command with `-p HOST_PORT:CONTAINER_PORT` when needed.
# Defaults bind to localhost on the host. Use 0.0.0.0 only when you mean to
# expose the port from a VPS, and put a firewall or reverse proxy in front.
PORT_BIND_ADDRESS=127.0.0.1
HOST_PORT_3000=3000
HOST_PORT_8000=8000
HOST_PORT_8080=8080

# Optional: Anthropic API key for normal Claude Code runs. Keep .env private.
# For Claude Code Remote Control, use real Claude Code Anthropic auth in the
# persisted agent home; Ollama-style placeholder auth is not enough.
# ANTHROPIC_API_KEY=sk-ant-...

# Resource caps. Not security; just limits for runaway commands.
# On a VPS, adjust these to the machine size.
MEM_LIMIT=4g
CPU_LIMIT=4
