# templates/codex-ollama — environment.
#
# Copy this file to .env. Editing WORKSPACE_PATH and AGENT_HOME_PATH is best,
# but setup-host.sh falls back to ~/sannux-data when they are empty.

# UID/GID matched to the host user. Run `id -u` and `id -g` to get yours.
# On macOS this is less critical because Docker Desktop translates ownership,
# but using the real values keeps examples consistent across systems.
USER_UID=1000
USER_GID=1000

# Project folder mounted at /workspace inside the container.
# Use an absolute path outside this repo.
# Example: WORKSPACE_PATH=/srv/example-data/workspaces/my-project
WORKSPACE_PATH=

# Persistent agent home mounted at /home/agent inside the container.
# This stores auth, config, history, logs, and memory.
# Example: AGENT_HOME_PATH=/srv/example-data/agent-homes/codex-ollama
AGENT_HOME_PATH=

# Terminal colors for TUI agents. xterm-256color works well in most terminals.
SANNUX_TERM=xterm-256color
SANNUX_COLORTERM=truecolor
# Optional: force ANSI colors even when a tool is unsure. Can make piped output noisy.
# SANNUX_FORCE_COLOR=1

# Ollama endpoint that exposes an OpenAI-compatible /v1 API.
# If Ollama runs on the Docker host, host.docker.internal is the most portable
# option. For another machine on your LAN, use its IP address instead.
OLLAMA_BASE_URL=http://host.docker.internal:11434/v1

# Local model served by Ollama. The default model_catalog.json in this template
# contains metadata for this exact slug. If you change it, update the catalog too.
CODEX_MODEL=local-model:8b

# Codex config values rendered into AGENT_HOME_PATH/.codex/config.toml by
# setup-host.sh. The container is the sandbox boundary for this template, so the
# default Codex policy is intentionally full-yolo inside the container.
CODEX_MODEL_PROVIDER=ollama_lan
CODEX_MODEL_PROVIDER_NAME=Ollama
CODEX_PROFILE=local-model-8b
CODEX_PERSONALITY=friendly
CODEX_MODEL_REASONING_EFFORT=high
CODEX_APPROVAL_POLICY=never
CODEX_SANDBOX_MODE=danger-full-access

# Codex metadata for the local model. Keep this path inside the container.
CODEX_MODEL_CATALOG_PATH=/opt/sannux/model_catalog.json

# Resource caps. Not security; just limits for runaway commands.
# On a VPS, adjust these to the machine size.
MEM_LIMIT=4g
CPU_LIMIT=4
