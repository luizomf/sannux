# templates/remote-dev — environment.
#
# Copy this file to .env and edit, or run `just setup remote-dev` from the
# repo root to fill the paths, generate a dedicated SSH key, and start SSH.

# Linux user created inside the container and written to the generated SSH config.
# Keep the default unless you have a reason to expose a different SSH username.
REMOTE_USER=agent

# UID/GID for the Linux user inside the container.
# The setup script fills these automatically for local use.
USER_UID=1000
USER_GID=1000

# Project folder mounted at /workspace inside the container.
# `just setup remote-dev` fills this automatically.
# If you configure by hand, create it first and use a dedicated absolute path
# outside this repo. Do not point it at / or your real home directory.
# Example: WORKSPACE_PATH=/srv/remote-dev/workspaces/my-project
WORKSPACE_PATH=

# Persistent remote-dev home mounted at /home/${REMOTE_USER} inside the container.
# This stores SSH authorized keys, app auth/config, extensions, and cache.
# Runtime Unix sockets use an in-container tmpfs so macOS bind mounts do not
# break tools that chmod socket files.
# `just setup remote-dev` fills this automatically.
# Use a dedicated absolute path; do not point it at / or your real home directory.
# Example: AGENT_HOME_PATH=/srv/remote-dev/agent-homes/remote-dev
AGENT_HOME_PATH=

# SSH published by the remote-dev service.
# Keep SSH_BIND_ADDRESS=127.0.0.1 unless you know you want to expose SSH.
SSH_BIND_ADDRESS=127.0.0.1
HOST_SSH_PORT=2222
SSH_HOST_ALIAS=sannux-remote-dev

# Terminal colors.
SANNUX_TERM=xterm-256color
SANNUX_COLORTERM=truecolor
# Optional: force ANSI colors even when a tool is unsure. Can make piped output noisy.
# SANNUX_FORCE_COLOR=1

# Optional preview ports for apps started inside the SSH container.
# Defaults bind to localhost on the host. Use 0.0.0.0 only when you mean to
# expose the port from a VPS, and put a firewall or reverse proxy in front.
PORT_BIND_ADDRESS=127.0.0.1
HOST_PORT_3000=3000
HOST_PORT_8000=8000
HOST_PORT_8080=8080

# Resource caps. Not security; just limits for runaway commands.
# On a VPS, adjust these to the machine size.
MEM_LIMIT=4g
CPU_LIMIT=4
