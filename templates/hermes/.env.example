# templates/hermes — environment.
#
# Copy this file to .env and edit, or run ./setup-host.sh to fill safe defaults.
# Keep WORKSPACE_PATH and AGENT_HOME_PATH outside the sannux repository.

# UID/GID matched to the host user. Run `id -u` and `id -g` to get yours.
# On macOS this is less critical because Docker Desktop translates ownership,
# but using the real values keeps examples consistent across systems.
USER_UID=1000
USER_GID=1000

# Project folder mounted at /workspace inside the container.
# Use an absolute path outside this repo. ./setup-host.sh creates it when blank.
# Example: WORKSPACE_PATH=/srv/example-data/workspaces/my-project
WORKSPACE_PATH=

# Persistent agent home mounted at /home/agent inside the container.
# This stores auth, config, gateway state, sessions, logs, and memory.
# ./setup-host.sh creates it when blank.
# Example: AGENT_HOME_PATH=/srv/example-data/agent-homes/hermes
AGENT_HOME_PATH=

# Terminal colors for TUI agents. xterm-256color works well in most terminals.
SANNUX_TERM=xterm-256color
SANNUX_COLORTERM=truecolor
# Optional: force ANSI colors even when a tool is unsure. Can make piped output noisy.
# SANNUX_FORCE_COLOR=1

# Optional preview ports for apps started by the always-on gateway daemon.
# Regular `docker compose run --rm agent` sessions publish ports explicitly
# per command with `-p HOST_PORT:CONTAINER_PORT` when needed.
# Defaults bind to localhost on the host. Use 0.0.0.0 only when you mean to
# expose the port from a VPS, and put a firewall or reverse proxy in front.
# The dashboard exposes Hermes config and API-key management; keep it private.
PORT_BIND_ADDRESS=127.0.0.1
HOST_PORT_3000=3000
HOST_PORT_8000=8000
HOST_PORT_8080=8080
HOST_PORT_DASHBOARD=9119

# Provider keys. Set whichever you actually use; all optional.
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# OPENROUTER_API_KEY=sk-or-...
# NOUS_PORTAL_API_KEY=...
# NVIDIA_API_KEY=...
# ELEVENLABS_API_KEY=...
#
# Example OpenAI-compatible endpoint:
# https://models.example.com/v1
# Keep the key scoped to this Hermes template. You can paste it in the Hermes
# setup wizard, or reference this env var from ~/.hermes/config.yaml.
# MODEL_ACCESS_KEY=sk-...

# Resource caps. Not security; just limits for runaway commands.
# Hermes can pull in browser automation and voice extras, so this default is
# higher than the other templates. On a VPS, adjust these to the machine size.
MEM_LIMIT=8g
CPU_LIMIT=4
